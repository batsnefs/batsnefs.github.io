{
  "headers": [
    {
      "source": "/(assets/:path*|css/:path*|js/:path*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|ttf|png|jpg|jpeg|svg|gif|ico|avif|mp3))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
